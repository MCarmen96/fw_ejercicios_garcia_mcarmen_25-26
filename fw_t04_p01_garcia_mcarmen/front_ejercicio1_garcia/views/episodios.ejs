<%- include('partials/header') %>

    <section>HELLO DESDE EPISODIOS!!</section>

    <div class="overflow-x-auto rounded-box border border-base-content/5 bg-base-100">

        <table class="table">
            <!-- head -->
            <thead>
                <tr>

                    <th>Code</th>
                    <th>Title</th>
                    <th>Year</th>
                    <th></th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <% episodes.forEach(function(element,index){ %>
                    <!-- row 1 -->
                    <tr>
                        <th>
                            <%= element.code%>
                        </th>
                        <td>
                            <%= element.title%>
                        </td>
                        <td>
                            <%= element.year%>
                        </td>
                        <td>
                            <!-- Open the modal using ID.showModal() method -->
                            <button class="btn btn-info"
                                onclick="infoModal('<%= element._id %>','box-<%=index%>','my_modal_<%=index%>')">Ver
                                detalles</button>
                        </td>
                        <td><button class="btn btn-warning"
                                onclick="deleteEpisode('<%= element._id %>',this)">Eliminar</button></td>
                    </tr>
                    <% }); %>

            </tbody>
        </table>
        <dialog id="my_modal" class="modal">
            <div class="modal-box" id="box">

            </div>
        </dialog>

        <dialog id="modal_confirmacion" class="modal">
            <div class="modal-box" id="box-confirmacion">
                <h3 class="font-bold text-lg">¿Estás seguro?</h3>
                <div class="modal-action">
                    <button id="btn_no" class="btn">Cancelar</button>
                    <button id="btn_si" class="btn btn-error">Sí, borrar</button </div>
                </div>
        </dialog>
    </div>

    <ul>
        <li>

        </li>
    </ul>
    <%- include('partials/footer') %>