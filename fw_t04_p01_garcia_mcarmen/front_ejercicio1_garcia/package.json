{
  "name": "front-ejercicio1-garcia",
  "version": "0.0.0",
  "private": true,
 "scripts": {
  "start": "node ./bin/www.js",
  "dev": "nodemon ./bin/www.js",
  "build:css": "npx tailwindcss -i ./src/styles/input.css -o ./public/stylesheets/output.css",
  "watch:css": "npx tailwindcss -i ./src/styles/input.css -o ./public/stylesheets/output.css --watch",
  "dev:all": "concurrently \"npm run dev\" \"npm run watch:css\""
},
  "dependencies": {
    "axios": "^1.13.6",
    "concurrently": "^9.2.1",
    "cookie-parser": "~1.4.4",
    "daisyui": "^5.5.19",
    "debug": "~2.6.9",
    "dotenv": "^17.3.1",
    "ejs": "~2.6.1",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "morgan": "~1.9.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.2.2"
  }
}
