{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Depurar Express (bin/www.js)",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/bin/www.js",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "restart": true
    }
  ]
}